<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.github.zh.mylangchain4jtools.mapper.ChatRecordMapper">
    <resultMap id="BaseResultMap" type="io.github.zh.mylangchain4jtools.entity.ChatRecord">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="user_id" property="userId" jdbcType="BIGINT"/>
        <result column="role" property="role" jdbcType="VARCHAR"/>
        <result column="content" property="content" jdbcType="LONGVARCHAR"/>
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
        <result column="updated_at" property="updatedAt" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, user_id, role, content, created_at, updated_at
    </sql>

    <insert id="insert" parameterType="io.github.zh.mylangchain4jtools.entity.ChatRecord" useGeneratedKeys="true"
            keyProperty="id">
        insert into chat_records (user_id, role, content, created_at, updated_at)
        values (#{userId}, #{role}, #{content}, #{createdAt}, #{updatedAt})
    </insert>
    <select id="selectById" parameterType="java.lang.Long" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from chat_records
        where id = #{id}
    </select>
    <select id="selectByUserId" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from chat_records
        where user_id = #{userId}
        order by created_at desc
        <if test="limit != null">
            LIMIT #{limit}
        </if>
    </select>
    <select id="selectByUserIdAndRole" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from chat_records
        where user_id = #{userId}
          and role = #{role}
        order by created_at desc
        <if test="limit != null">
            LIMIT #{limit}
        </if>
    </select>
    <delete id="deleteByUserId">
        delete
        from chat_records
        where user_id = #{userId}
    </delete>
    <insert id="batchInsert" parameterType="java.util.List">
        INSERT INTO chat_records (user_id, role, content, created_at, updated_at)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.userId}, #{item.role}, #{item.content}, #{item.createdAt}, #{item.updatedAt})
        </foreach>
    </insert>
</mapper>