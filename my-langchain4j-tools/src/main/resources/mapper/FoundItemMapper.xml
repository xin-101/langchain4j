<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.github.zh.mylangchain4jtools.mapper.FoundItemMapper">

    <resultMap id="BaseResultMap" type="io.github.zh.mylangchain4jtools.entity.FoundItem">
        <id column="id" property="id" />
        <result column="user_id" property="userId" />
        <result column="item_name" property="itemName" />
        <result column="item_description" property="itemDescription" />
        <result column="category" property="category" />
        <result column="found_location" property="foundLocation" />
        <result column="found_time" property="foundTime" />
        <result column="contact_info" property="contactInfo" />
        <result column="contact_name" property="contactName" />
        <result column="remarks" property="remarks" />
        <result column="status" property="status" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
    </resultMap>

    <insert id="insert" parameterType="io.github.zh.mylangchain4jtools.entity.FoundItem" useGeneratedKeys="true" keyProperty="id">
        insert into found_items (user_id, item_name, item_description, category, found_location, found_time, contact_info, contact_name, remarks, status, create_time, update_time)
        values (#{userId}, #{itemName}, #{itemDescription}, #{category}, #{foundLocation}, #{foundTime}, #{contactInfo}, #{contactName}, #{remarks}, #{status}, #{createTime}, #{updateTime})
    </insert>

    <select id="selectById" resultType="io.github.zh.mylangchain4jtools.entity.FoundItem">
        select * from found_items where id = #{id}
    </select>

    <select id="selectByUserId" resultType="io.github.zh.mylangchain4jtools.entity.FoundItem">
        select * from found_items where user_id = #{userId}
    </select>

    <select id="searchByKeyword" resultType="io.github.zh.mylangchain4jtools.entity.FoundItem">
        select * from found_items 
        <where>
            <if test="keyword != null and keyword != ''">
                and (item_name like CONCAT('%', #{keyword}, '%') or item_description like CONCAT('%', #{keyword}, '%'))
            </if>
            <if test="category != null and category != ''">
                and category = #{category}
            </if>
            <if test="location != null and location != ''">
                and found_location = #{location}
            </if>
        </where>
    </select>

    <update id="updateStatus">
        update found_items set status = #{status} where id = #{id}
    </update>

    <update id="update">
        update found_items
        <set>
            <if test="itemName != null">item_name = #{itemName},</if>
            <if test="itemDescription != null">item_description = #{itemDescription},</if>
            <if test="category != null">category = #{category},</if>
            <if test="foundLocation != null">found_location = #{foundLocation},</if>
            <if test="foundTime != null">found_time = #{foundTime},</if>
            <if test="contactInfo != null">contact_info = #{contactInfo},</if>
            <if test="contactName != null">contact_name = #{contactName},</if>
            <if test="remarks != null">remarks = #{remarks},</if>
            <if test="status != null">status = #{status},</if>
            update_time = #{updateTime}
        </set>
        where id = #{id}
    </update>
</mapper>